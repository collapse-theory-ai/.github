{
  "packages": {
    ".": {
      "release-type": "rust",
      "package-name": "PROJECT_NAME",
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        },
        {
          "type": "toml",
          "path": "uv.lock",
          "jsonpath": "$.package[?(@.name==\"PROJECT_NAME\")].version"
        }
      ]
    }
  }
}
